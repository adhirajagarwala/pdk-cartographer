/* Tiny synthetic Liberty fixture for parser tests.
 * Educational only; not copied from Sky130 or any real PDK.
 */

library(tiny_synthetic_sequential) {
  delay_model : table_lookup;
  time_unit : "1ns";
  voltage_unit : "1V";

  cell(TINY_DFF_X1) {
    area : 4.80;

    pin(CLK) {
      direction : input;
      capacitance : 0.0030;
      clock : true;
    }

    pin(D) {
      direction : input;
      capacitance : 0.0024;
    }

    pin(Q) {
      direction : output;
      function : "IQ";

      timing() {
        related_pin : "CLK";
        timing_type : rising_edge;
      }

      timing() {
        related_pin : "D";
        timing_sense : non_unate;
        timing_type : setup_rising;
      }
    }
  }
}

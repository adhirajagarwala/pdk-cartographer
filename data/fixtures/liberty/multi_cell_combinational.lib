/* This is a synthetic educational Liberty fixture for pdk-cartographer tests.
 * It is not copied from Sky130 or any real PDK.
 */

library(synthetic_multi_cell_combinational) {
  delay_model : table_lookup;
  time_unit : "1ns";
  voltage_unit : "1V";

  cell(INV_X1) {
    area : 1.20;

    pin(A) {
      direction : input;
      capacitance : 0.0018;
    }

    pin(Y) {
      direction : output;
      function : "!A";
    }
  }

  cell(NAND2_X1) {
    area : 1.85;

    pin(A) {
      direction : input;
      capacitance : 0.0022;
    }

    pin(B) {
      direction : input;
      capacitance : 0.0022;
    }

    pin(Y) {
      direction : output;
      function : "!(A & B)";
    }
  }

  cell(NOR2_X1) {
    area : 1.95;

    pin(A) {
      direction : input;
      capacitance : 0.0020;
    }

    pin(B) {
      direction : input;
      capacitance : 0.0020;
    }

    pin(Y) {
      direction : output;
      function : "!(A | B)";
    }
  }
}

/* Tiny synthetic Liberty fixture for parser tests.
 * Educational only; not copied from Sky130 or any real PDK.
 */

library(tiny_synthetic_combinational) {
  delay_model : table_lookup;
  time_unit : "1ns";
  voltage_unit : "1V";
  current_unit : "1mA";

  cell(TINY_INV_X1) {
    area : 1.40;

    pin(A) {
      direction : input;
      capacitance : 0.0021;
    }

    pin(Y) {
      direction : output;
      function : "!A";

      timing() {
        related_pin : "A";
        timing_sense : negative_unate;
        timing_type : combinational;
      }
    }
  }
}
